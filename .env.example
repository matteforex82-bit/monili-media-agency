# Copia questo file in .env e inserisci le tue chiavi API

# Anthropic (obbligatorio)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini Image Generation (per shooting AI)
GOOGLE_API_KEY=AIza...

# Midjourney API (opzionale, alternativa a Gemini)
MJ_API_KEY=
MJ_API_URL=https://api.midjourney.com/v1

# Configurazione generazione visiva
# "gemini" | "midjourney" | "manual" (solo prompts, no API call)
IMAGE_GENERATOR=gemini
